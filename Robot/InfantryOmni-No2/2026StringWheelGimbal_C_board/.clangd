CompileFlags:
  Remove:
    - -mcpu=*
    - -mfpu=*
    - -mfloat-abi=*
    - -marm
    - -fstack-usage
    - -fdata-sections
    - -ffunction-sections
    - -fno-rtti
    - -fno-exceptions
    - -fno-threadsafe-statics
    - -fno-use-cxa-atexit
  Add:
    - -std=c++17
    - -stdlib=libstdc++
    - --gcc-toolchain=C:/ClionToolchains/gcc-arm-none-eabi-10.3-2021.10
